generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Plan {
  FREE
  PRO
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum FinancialMonthStatus {
  OPEN
  CLOSED
}

enum PaymentStatus {
  PENDING
  PAID
}

enum FixedCostPaymentMethod {
  PIX
  BANK_SLIP
  DEBIT
  CREDIT_CARD
  CASH
}

enum BankAccountType {
  CHECKING
  SAVINGS
  DIGITAL
  CASH
  INVESTMENT
}

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String    @unique
  emailVerified        DateTime?
  image                String?
  passwordHash         String?
  plan                 Plan      @default(FREE)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  categories   Category[]
  transactions Transaction[]
  budgets      Budget[]
  financialMonths FinancialMonth[]
  cards       Card[]
  cardInvoices CardInvoice[]
  fixedCosts  FixedCost[]
  fixedCostOccurrences FixedCostOccurrence[]
  bankAccounts BankAccount[]
  bankAccountMovements BankAccountMovement[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id     String          @id @default(cuid())
  name   String
  icon   String          @default("wallet")
  color  String          @default("#0EA882")
  type   TransactionType @default(EXPENSE)
  userId String

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]
  fixedCosts   FixedCost[]

  @@unique([name, userId])
}

model Transaction {
  id          String          @id @default(cuid())
  amount      Float
  type        TransactionType
  description String?
  date        DateTime        @default(now())
  categoryId  String
  userId      String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  category Category @relation(fields: [categoryId], references: [id])
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FinancialMonth {
  id        String               @id @default(cuid())
  month     String
  status    FinancialMonthStatus @default(OPEN)
  userId    String
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardInvoices         CardInvoice[]
  fixedCostOccurrences FixedCostOccurrence[]

  @@unique([month, userId])
}

model Card {
  id         String   @id @default(cuid())
  name       String
  brand      String?
  color      String   @default("#22C55E")
  closingDay Int?
  dueDay     Int?
  bankAccountId String?
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  invoices   CardInvoice[]
  fixedCosts FixedCost[]

  @@unique([name, userId])
}

model BankAccount {
  id             String          @id @default(cuid())
  name           String
  institution    String?
  type           BankAccountType @default(CHECKING)
  color          String          @default("#22C55E")
  initialBalance Float           @default(0)
  active         Boolean         @default(true)
  userId         String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards     Card[]
  fixedCosts FixedCost[]
  movements BankAccountMovement[]

  @@unique([name, userId])
}

model BankAccountMovement {
  id            String          @id @default(cuid())
  bankAccountId String
  amount        Float
  type          TransactionType
  description   String?
  date          DateTime        @default(now())
  userId        String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CardInvoice {
  id                    String        @id @default(cuid())
  cardId                String
  financialMonthId      String
  month                 String
  dueDate               DateTime
  amount                Float
  status                PaymentStatus @default(PENDING)
  paidAt                DateTime?
  paymentMethod         String?
  paymentBankAccountId  String?
  bankAccountMovementId String?
  userId                String
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  card           Card           @relation(fields: [cardId], references: [id], onDelete: Cascade)
  financialMonth FinancialMonth @relation(fields: [financialMonthId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cardId, month, userId])
}

model FixedCost {
  id             String                 @id @default(cuid())
  name           String
  defaultAmount  Float
  categoryId     String
  paymentMethod  FixedCostPaymentMethod
  paidInsideCard Boolean                @default(false)
  cardId         String?
  bankAccountId  String?
  active         Boolean                @default(true)
  userId         String
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category              @relation(fields: [categoryId], references: [id])
  card        Card?                 @relation(fields: [cardId], references: [id], onDelete: SetNull)
  bankAccount BankAccount?          @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  occurrences FixedCostOccurrence[]

  @@unique([name, userId])
}

model FixedCostOccurrence {
  id               String        @id @default(cuid())
  fixedCostId      String
  financialMonthId String
  month            String
  amount           Float
  status           PaymentStatus @default(PENDING)
  paidAt           DateTime?
  userId           String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  fixedCost      FixedCost      @relation(fields: [fixedCostId], references: [id], onDelete: Cascade)
  financialMonth FinancialMonth @relation(fields: [financialMonthId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([fixedCostId, month, userId])
}

model Budget {
  id         String @id @default(cuid())
  amount     Float
  month      String
  categoryId String
  userId     String

  category Category @relation(fields: [categoryId], references: [id])
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([categoryId, month, userId])
}
